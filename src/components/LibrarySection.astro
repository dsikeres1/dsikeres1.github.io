---
const packages = [
  {
    name: 'react-date-range-picker-tailwind4',
    label: 'Tailwind v4',
    description: 'For shadcn/ui and Tailwind v4 projects. Pre-styled, dark mode ready.',
    install: 'pnpm add react-date-range-picker-tailwind4',
  },
  {
    name: 'react-date-range-picker-tailwind3',
    label: 'Tailwind v3',
    description: 'For existing Tailwind v3 projects. Drop-in ready with dark mode.',
    install: 'pnpm add react-date-range-picker-tailwind3',
  },
  {
    name: 'react-date-range-picker-styled',
    label: 'Styled',
    description: 'Vanilla CSS with CSS variables. Works with any framework or none.',
    install: 'pnpm add react-date-range-picker-styled',
  },
  {
    name: 'react-date-range-picker-headless',
    label: 'Headless',
    description: 'Unstyled hooks for full control over markup and styling. Zero dependencies.',
    install: 'pnpm add react-date-range-picker-headless',
  },
]

const shadcnComponents = [
  { name: 'date-picker', label: 'Date Picker' },
  { name: 'date-range-picker', label: 'Date Range Picker' },
  { name: 'date-time-picker', label: 'Date Time Picker' },
  { name: 'date-range-time-picker', label: 'Date Range Time Picker' },
  { name: 'time-picker', label: 'Time Picker' },
]

const features = [
  { icon: '📦', text: 'Zero Dependencies' },
  { icon: '🎯', text: '5 Picker Types' },
  { icon: '🌍', text: '15 Locales' },
  { icon: '🌙', text: 'Dark Mode' },
  { icon: '♿', text: 'Accessible' },
  { icon: '⌨️', text: 'Keyboard Nav' },
]
---

<section class="overflow-hidden px-4 py-12 sm:px-6 md:py-16">
  <div class="mx-auto max-w-5xl overflow-hidden rounded-2xl border border-zinc-800/50 bg-zinc-900/20 p-5 sm:p-8 md:p-12">
    <!-- Header: Logo + Title + Description -->
    <div class="flex flex-col items-center text-center">
      <img
        src="/rdrp-logo.svg"
        alt="react-date-range-picker logo"
        class="h-16 w-16 md:h-20 md:w-20"
        width="80"
        height="80"
      />
      <h2 class="mt-6 text-2xl font-bold tracking-tight sm:text-3xl md:text-4xl">
        react-date-range-picker
      </h2>
      <p class="mt-3 text-base text-zinc-400 sm:text-lg">
        A headless, composable date &amp; date range picker for React.
      </p>
    </div>

    <!-- Shields.io Badges (common only) -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
      <a href="https://github.com/dsikeres1/react-date-range-picker" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/github/stars/dsikeres1/react-date-range-picker?style=flat-square&color=e3b341" alt="GitHub stars" loading="lazy" width="80" height="20" />
      </a>
      <img src="https://img.shields.io/npm/l/react-date-range-picker-headless?style=flat-square&color=blue" alt="license" loading="lazy" width="80" height="20" />
      <img src="https://img.shields.io/badge/TypeScript-strict-3178c6?style=flat-square" alt="TypeScript" loading="lazy" width="120" height="20" />
    </div>

    <!-- Features -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm text-zinc-400 sm:gap-x-6">
      {features.map((f) => (
        <span class="inline-flex items-center gap-1.5">
          <span>{f.icon}</span>
          <span>{f.text}</span>
        </span>
      ))}
    </div>

    <!-- Package Cards -->
    <div class="mt-14 grid min-w-0 gap-4 overflow-hidden sm:gap-5 md:grid-cols-2 lg:grid-cols-4">
      {packages.map((pkg) => (
        <div class="group flex min-w-0 flex-col overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900 p-4 transition-colors hover:border-zinc-700 sm:p-5">
          <h3 class="text-lg font-semibold">{pkg.label}</h3>
          <!-- Per-package badges -->
          <div class="mt-2 flex items-center gap-1.5">
            <img src={`https://img.shields.io/npm/v/${pkg.name}?style=flat-square&label=&color=cb3837`} alt="version" loading="lazy" class="h-[18px]" width="60" height="18" />
            <img src={`https://img.shields.io/npm/dw/${pkg.name}?style=flat-square&label=weekly&color=234`} alt="downloads" loading="lazy" class="h-[18px]" width="90" height="18" />
          </div>
          <p class="mt-2 text-sm text-zinc-400">{pkg.description}</p>
          <div class="mt-auto pt-3">
            <a
              href={`https://www.npmjs.com/package/${pkg.name}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-xs text-zinc-400 transition-colors hover:text-red-400"
            >
              <svg class="h-3.5 w-3.5" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
                <path d="M0 256V0h256v256H0z" fill="currentColor" />
                <path d="M48 48v160h80v-128h48v128h32V48H48z" fill="#fff" />
              </svg>
              <span>View on npm</span>
              <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
          <div class="mt-3 flex items-center gap-2 rounded-lg bg-zinc-950 px-3 py-2">
            <code class="min-w-0 flex-1 overflow-x-auto text-[11px] text-zinc-300 whitespace-nowrap sm:text-xs">
              {pkg.install}
            </code>
            <button
              class="copy-btn shrink-0 cursor-pointer rounded p-1 text-zinc-500 transition-colors hover:text-zinc-200"
              data-copy={pkg.install}
              aria-label="Copy install command"
            >
              <svg class="copy-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
              </svg>
              <svg class="check-icon hidden h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- shadcn/ui Registry -->
    <div class="mt-10 overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 sm:p-6">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
        <span class="w-fit shrink-0 rounded-md bg-zinc-800 px-2 py-1 text-xs font-medium text-zinc-300">shadcn/ui</span>
        <p class="text-sm text-zinc-400">Using Tailwind v4? Add components directly via shadcn registry:</p>
      </div>
      <div class="mt-4 flex flex-col gap-3">
        {shadcnComponents.map((comp) => (
          <div>
            <span class="mb-1.5 block text-[11px] font-medium text-zinc-400 sm:text-xs">{comp.label}</span>
            <div class="flex items-center gap-2 overflow-hidden rounded-lg bg-zinc-950 px-3 py-2 sm:px-4 sm:py-2.5">
              <code class="min-w-0 flex-1 overflow-x-auto text-[11px] text-zinc-300 whitespace-nowrap sm:text-xs">npx shadcn add https://dsikeres1.github.io/react-date-range-picker/r/{comp.name}.json</code>
              <button
                class="copy-btn shrink-0 cursor-pointer rounded p-1 text-zinc-500 transition-colors hover:text-zinc-200"
                data-copy={`npx shadcn add https://dsikeres1.github.io/react-date-range-picker/r/${comp.name}.json`}
                aria-label={`Copy ${comp.label} install command`}
              >
                <svg class="copy-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
                </svg>
                <svg class="check-icon hidden h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Links -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        href="https://dsikeres1.github.io/react-date-range-picker/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        Docs
      </a>
      <a
        href="https://github.com/dsikeres1/react-date-range-picker"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"
          />
        </svg>
        GitHub Repository
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy')
      if (!text) return

      await navigator.clipboard.writeText(text)

      const copyIcon = btn.querySelector('.copy-icon') as HTMLElement
      const checkIcon = btn.querySelector('.check-icon') as HTMLElement

      copyIcon.classList.add('hidden')
      checkIcon.classList.remove('hidden')

      setTimeout(() => {
        copyIcon.classList.remove('hidden')
        checkIcon.classList.add('hidden')
      }, 2000)
    })
  })
</script>
