---
const packages = [
  {
    name: 'react-date-range-picker-headless',
    label: 'Headless',
    description: 'Zero dependencies. Unstyled hooks — full control over markup and styling.',
    install: 'pnpm add react-date-range-picker-headless',
  },
  {
    name: 'react-date-range-picker-styled',
    label: 'Styled',
    description: 'Pre-styled with vanilla CSS and CSS variables. No framework needed.',
    install: 'pnpm add react-date-range-picker-styled',
  },
  {
    name: 'react-date-range-picker-tailwind3',
    label: 'Tailwind v3',
    description: 'Pre-styled with Tailwind CSS v3. Drop-in ready with dark mode.',
    install: 'pnpm add react-date-range-picker-tailwind3',
  },
  {
    name: 'react-date-range-picker-tailwind4',
    label: 'Tailwind v4',
    description: 'Pre-styled with Tailwind CSS v4. shadcn/ui compatible.',
    install: 'pnpm add react-date-range-picker-tailwind4',
  },
]

const features = [
  { icon: '📦', text: 'Zero Dependencies' },
  { icon: '🎯', text: '5 Picker Types' },
  { icon: '🌍', text: '15 Locales' },
  { icon: '🌙', text: 'Dark Mode' },
  { icon: '♿', text: 'Accessible' },
  { icon: '⌨️', text: 'Keyboard Nav' },
]
---

<section class="px-6 py-12 md:py-16">
  <div class="mx-auto max-w-5xl rounded-2xl border border-zinc-800/50 bg-zinc-900/20 p-8 md:p-12">
    <!-- Header: Logo + Title + Description -->
    <div class="flex flex-col items-center text-center">
      <img
        src="/rdrp-logo.svg"
        alt="react-date-range-picker logo"
        class="h-16 w-16 md:h-20 md:w-20"
      />
      <h2 class="mt-6 text-3xl font-bold tracking-tight md:text-4xl">
        react-date-range-picker
      </h2>
      <p class="mt-3 text-lg text-zinc-400">
        A headless, composable date &amp; date range picker for React.
      </p>
    </div>

    <!-- Shields.io Badges -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-2">
      <a href="https://www.npmjs.com/package/react-date-range-picker-headless" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/npm/v/react-date-range-picker-headless?style=flat-square&label=npm&color=cb3837" alt="npm version" loading="lazy" />
      </a>
      <a href="https://www.npmjs.com/package/react-date-range-picker-headless" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/npm/dw/react-date-range-picker-headless?style=flat-square&label=downloads&color=234" alt="npm downloads" loading="lazy" />
      </a>
      <a href="https://github.com/dsikeres1/react-date-range-picker" target="_blank" rel="noopener noreferrer">
        <img src="https://img.shields.io/github/stars/dsikeres1/react-date-range-picker?style=flat-square&color=e3b341" alt="GitHub stars" loading="lazy" />
      </a>
      <img src="https://img.shields.io/npm/l/react-date-range-picker-headless?style=flat-square&color=blue" alt="license" loading="lazy" />
      <img src="https://img.shields.io/badge/TypeScript-strict-3178c6?style=flat-square" alt="TypeScript" loading="lazy" />
    </div>

    <!-- Features -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-zinc-400">
      {features.map((f) => (
        <span class="inline-flex items-center gap-1.5">
          <span>{f.icon}</span>
          <span>{f.text}</span>
        </span>
      ))}
    </div>

    <!-- Package Cards -->
    <div class="mt-14 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {packages.map((pkg) => (
        <div class="group rounded-xl border border-zinc-800 bg-zinc-900 p-5 transition-colors hover:border-zinc-700">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-semibold">{pkg.label}</h3>
            <a
              href={`https://www.npmjs.com/package/${pkg.name}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-zinc-600 transition-colors hover:text-red-400"
              aria-label={`${pkg.label} on npm`}
              title="View on npm"
            >
              <svg class="h-5 w-5" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
                <path d="M0 256V0h256v256H0z" fill="currentColor" />
                <path d="M48 48v160h80v-128h48v128h32V48H48z" fill="#fff" />
              </svg>
            </a>
          </div>
          <p class="mt-2 text-sm text-zinc-400">{pkg.description}</p>
          <div class="mt-4 flex items-center gap-2 rounded-lg bg-zinc-950 px-3 py-2">
            <code class="flex-1 overflow-x-auto text-xs text-zinc-300 whitespace-nowrap">
              {pkg.install}
            </code>
            <button
              class="copy-btn shrink-0 cursor-pointer rounded p-1 text-zinc-500 transition-colors hover:text-zinc-200"
              data-copy={pkg.install}
              aria-label="Copy install command"
            >
              <svg class="copy-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
                <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
              </svg>
              <svg class="check-icon hidden h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- shadcn/ui Install -->
    <div class="mt-10 rounded-xl border border-zinc-800 bg-zinc-900/50 p-6">
      <div class="flex items-center gap-3">
        <span class="rounded-md bg-zinc-800 px-2 py-1 text-xs font-medium text-zinc-300">shadcn/ui</span>
        <p class="text-sm text-zinc-400">Using Tailwind v4? Add the date picker directly via shadcn registry:</p>
      </div>
      <div class="mt-3 flex items-center gap-2 rounded-lg bg-zinc-950 px-4 py-3">
        <code class="flex-1 overflow-x-auto text-sm text-zinc-300 whitespace-nowrap">
          npx shadcn add https://dsikeres1.github.io/react-date-range-picker/r/date-picker.json
        </code>
        <button
          class="copy-btn shrink-0 cursor-pointer rounded p-1 text-zinc-500 transition-colors hover:text-zinc-200"
          data-copy="npx shadcn add https://dsikeres1.github.io/react-date-range-picker/r/date-picker.json"
          aria-label="Copy shadcn install command"
        >
          <svg class="copy-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" />
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" />
          </svg>
          <svg class="check-icon hidden h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Links -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a
        href="https://dsikeres1.github.io/react-date-range-picker/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
        </svg>
        Docs
      </a>
      <a
        href="https://github.com/dsikeres1/react-date-range-picker"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white"
      >
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"
          />
        </svg>
        GitHub
      </a>
      <a
        href="https://www.npmjs.com/package/react-date-range-picker-headless"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 px-5 py-2.5 text-sm font-medium text-zinc-300 transition-colors hover:border-zinc-500 hover:text-white"
      >
        <svg class="h-4 w-4" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M0 256V0h256v256H0z" />
          <path d="M48 48v160h80v-128h48v128h32V48H48z" fill="#18181b" />
        </svg>
        npm
      </a>
      <a
        href="https://buymeacoffee.com/dsikeres1"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-5 py-2.5 text-sm font-medium text-zinc-900 transition-colors hover:bg-amber-400"
      >
        ☕ Buy me a coffee
      </a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-copy')
      if (!text) return

      await navigator.clipboard.writeText(text)

      const copyIcon = btn.querySelector('.copy-icon') as HTMLElement
      const checkIcon = btn.querySelector('.check-icon') as HTMLElement

      copyIcon.classList.add('hidden')
      checkIcon.classList.remove('hidden')

      setTimeout(() => {
        copyIcon.classList.remove('hidden')
        checkIcon.classList.add('hidden')
      }, 2000)
    })
  })
</script>
