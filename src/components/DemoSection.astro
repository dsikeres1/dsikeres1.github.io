---
// TODO: 라이브러리 완성 후 실제 컴포넌트로 교체
// import { DateRangePicker } from '@dsikeres1/react-date-range-picker-tailwind4'

const DAYS = ['Su', 'Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa']

function generateMonth(year: number, month: number) {
  const firstDay = new Date(year, month, 1).getDay()
  const daysInMonth = new Date(year, month + 1, 0).getDate()
  const weeks: (number | null)[][] = []
  let week: (number | null)[] = Array(firstDay).fill(null)

  for (let d = 1; d <= daysInMonth; d++) {
    week.push(d)
    if (week.length === 7) {
      weeks.push(week)
      week = []
    }
  }
  if (week.length > 0) {
    while (week.length < 7) week.push(null)
    weeks.push(week)
  }
  return weeks
}

const jan = generateMonth(2026, 0)
const feb = generateMonth(2026, 1)

// Highlight range: Jan 15 ~ Feb 10
const rangeStart = { month: 0, day: 15 }
const rangeEnd = { month: 1, day: 10 }

function isInRange(month: number, day: number | null) {
  if (day === null) return false
  if (month === 0 && day >= rangeStart.day) return true
  if (month === 1 && day <= rangeEnd.day) return true
  return false
}

function isStart(month: number, day: number | null) {
  return month === rangeStart.month && day === rangeStart.day
}

function isEnd(month: number, day: number | null) {
  return month === rangeEnd.month && day === rangeEnd.day
}
---

<section class="px-6 py-24 md:py-32">
  <div class="mx-auto max-w-4xl">
    <h2 class="text-center text-3xl font-bold tracking-tight md:text-4xl">
      Live Demo
    </h2>
    <p class="mt-4 text-center text-sm text-zinc-500">
      Preview — will be replaced with the actual component.
    </p>

    <!-- Date range display -->
    <div class="mx-auto mt-10 max-w-md">
      <div class="rounded-lg border border-zinc-800 bg-zinc-900 px-4 py-3 text-center text-sm text-zinc-300">
        2026. 01. 15 &nbsp;→&nbsp; 2026. 02. 10
      </div>
    </div>

    {/* placeholder — 실제 컴포넌트로 교체 예정 */}
    <div class="mx-auto mt-4 grid max-w-2xl gap-4 md:grid-cols-2">
      {[
        { label: 'January 2026', weeks: jan, month: 0 },
        { label: 'February 2026', weeks: feb, month: 1 },
      ].map(({ label, weeks, month }) => (
        <div class="rounded-xl border border-zinc-800 bg-zinc-900 p-4">
          <div class="mb-3 text-center text-sm font-medium text-zinc-300">
            {label}
          </div>
          <div class="grid grid-cols-7 gap-px text-center text-xs">
            {DAYS.map((d) => (
              <div class="py-1 font-medium text-zinc-500">{d}</div>
            ))}
            {weeks.flat().map((day) => {
              const inRange = isInRange(month, day)
              const start = isStart(month, day)
              const end = isEnd(month, day)

              return (
                <div
                  class:list={[
                    'py-1.5 text-sm',
                    day === null && 'invisible',
                    inRange && !start && !end && 'bg-sky-500/15 text-sky-300',
                    start && 'rounded-l-md bg-sky-500 font-semibold text-white',
                    end && 'rounded-r-md bg-sky-500 font-semibold text-white',
                    !inRange && day !== null && 'text-zinc-500',
                  ]}
                >
                  {day}
                </div>
              )
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
